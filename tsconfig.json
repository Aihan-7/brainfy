{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "None",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "outFile": "script.js",
    "rootDir": "src",
    "removeComments": false,
    "sourceMap": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
