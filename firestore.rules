// ────────────────────────────────────────────────────────────────────────────
//  Firestore security rules for Brainfy
//
//  Goal: each signed-in user can read/write only their own
//  users/{uid} document. Nobody else can list, read, or write them.
//
//  TO APPLY:
//    1. Firebase Console → Firestore Database → Rules
//    2. Paste this file's contents in
//    3. Click "Publish"
//
//  Without these rules, the default (test-mode or restrictive) rules will
//  reject the client-side reads/writes and the sync chip will show
//  "Sync failed — tap to retry" forever.
// ────────────────────────────────────────────────────────────────────────────

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read + write only the document keyed by their own uid.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // (Future) subcollections under users/{uid}/...
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Community-shared decks. World-READABLE (that's the point of sharing), but
    // a user may only create/modify/delete decks they own. Validated on write
    // to prevent impersonation and cap size (anti-abuse). Card text is HTML-
    // escaped on render client-side, so public content can't inject markup.
    match /publicDecks/{deckId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.cards is list
        && request.resource.data.cards.size() > 0
        && request.resource.data.cards.size() <= 1000;

      allow update: if request.auth != null
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.cards is list
        && request.resource.data.cards.size() > 0
        && request.resource.data.cards.size() <= 1000;

      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }

    // Everything else: deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
