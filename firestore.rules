// ────────────────────────────────────────────────────────────────────────────
//  Firestore security rules for Brainfy
//
//  Goal: each signed-in user can read/write only their own
//  users/{uid} document. Nobody else can list, read, or write them.
//
//  TO APPLY:
//    1. Firebase Console → Firestore Database → Rules
//    2. Paste this file's contents in
//    3. Click "Publish"
//
//  Without these rules, the default (test-mode or restrictive) rules will
//  reject the client-side reads/writes and the sync chip will show
//  "Sync failed — tap to retry" forever.
// ────────────────────────────────────────────────────────────────────────────

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read + write only the document keyed by their own uid.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // (Future) subcollections under users/{uid}/...
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Everything else: deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
